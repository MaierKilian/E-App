rules_version = '2';

// Sicherheitsregeln für Firestore.
//
// Drei Bereiche:
//  1. users/{uid}        – Alt-Daten (ein Profil pro Nutzer). Bleibt bestehen für
//                          die einmalige Migration und als Sicherung.
//  2. profiles/{id}      – Wohnprofile (mehrere pro Nutzer, teilbar). Zugriff hat,
//                          wer in memberUids steht.
//  3. …/invites/{id}     – Einladungen: Die Dokument-ID ist ein langes, zufälliges
//                          Geheimnis und steckt im Einladungslink. Wer die ID kennt
//                          und angemeldet ist, darf der Wohnung beitreten, solange
//                          die Einladung aktiv ist. Der Besitzer verwaltet sie.
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Alt-Daten – unverändert.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Wohnprofile.
    match /profiles/{profileId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }

      // Lesen darf jedes Mitglied.
      allow read: if isMember();

      // Erstellen: nur für sich selbst als alleiniges Erst-Mitglied.
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids.hasOnly([request.auth.uid])
        && request.auth.uid in request.resource.data.memberUids;

      // Ändern darf jedes Mitglied – der Besitzer darf aber nicht heimlich
      // getauscht werden (Schutz vor Übernahme). Deckt auch das Entfernen von
      // Mitgliedern (durch den Besitzer) und das eigene Verlassen ab.
      allow update: if isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid;

      // Besitz übertragen: Nur der aktuelle Besitzer, nur an ein bestehendes
      // Mitglied. Der neue Besitzer wird 'owner', der bisherige 'editor' –
      // andere Felder dürfen sich dabei nicht ändern.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.ownerUid
        && request.resource.data.ownerUid != request.auth.uid
        && request.resource.data.ownerUid in resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['ownerUid', 'roles'])
        && request.resource.data.roles[request.resource.data.ownerUid] == 'owner'
        && request.resource.data.roles[request.auth.uid] == 'editor';

      // Beitritt per Einladungslink: Ein Nicht-Mitglied darf sich selbst als
      // Editor hinzufügen – ausschließlich die Mitgliedschaftsfelder, und nur
      // wenn die im Schreibvorgang genannte Einladung existiert und aktiv ist.
      allow update: if isSignedIn()
        && !(request.auth.uid in resource.data.memberUids)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['memberUids', 'roles', 'memberNames', 'joinInviteId'])
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.roles.diff(resource.data.roles).affectedKeys()
             .hasOnly([request.auth.uid])
        && request.resource.data.roles[request.auth.uid] == 'editor'
        && get(/databases/$(database)/documents/profiles/$(profileId)/invites/$(request.resource.data.joinInviteId)).data.active == true;

      // Löschen darf nur der Besitzer.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;

      // 3. Einladungen.
      match /invites/{inviteId} {
        function ownerUid() {
          return get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerUid;
        }

        // Einzelabruf: Wer die (geheime, zufällige) ID kennt und angemeldet
        // ist, darf die Einladung prüfen – nötig für den Beitritt.
        allow get: if request.auth != null;

        // Auflisten und Verwalten darf nur der Besitzer der Wohnung.
        allow list: if request.auth != null && request.auth.uid == ownerUid();
        allow create, update, delete: if request.auth != null && request.auth.uid == ownerUid();
      }
    }
  }
}

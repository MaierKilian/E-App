rules_version = '2';

// Sicherheitsregeln für Firestore.
// Grundsatz: Jeder Nutzer darf ausschließlich sein eigenes Dokument
// unter users/{uid} lesen und schreiben – und nur, wenn er angemeldet ist.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

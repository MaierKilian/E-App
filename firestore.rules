rules_version = '2';

// Sicherheitsregeln für Firestore.
//
// Drei Bereiche:
//  1. users/{uid}        – Alt-Daten (ein Profil pro Nutzer). Bleibt bestehen für
//                          die einmalige Migration und als Sicherung.
//  2. profiles/{id}      – Wohnprofile (mehrere pro Nutzer, teilbar). Zugriff hat,
//                          wer in memberUids steht.
//  3. …/invites/{id}     – Einladungen: Die Dokument-ID ist ein langes, zufälliges
//                          Geheimnis und steckt im Einladungslink. Wer die ID kennt
//                          und angemeldet ist, darf der Wohnung beitreten, solange
//                          die Einladung aktiv ist. Der Besitzer verwaltet sie.
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Alt-Daten – unverändert.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Wohnprofile.
    match /profiles/{profileId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }
      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerUid;
      }
      // Die Mitgliedschaftsfelder bleiben unangetastet (reiner Daten-Schreibvorgang).
      function membershipUnchanged() {
        return request.resource.data.memberUids == resource.data.memberUids
          && request.resource.data.roles == resource.data.roles
          && request.resource.data.memberNames == resource.data.memberNames;
      }
      // Der aufrufende Nutzer entfernt ausschließlich sich selbst (Wohnung verlassen):
      // nur die eigenen Einträge in memberUids/roles/memberNames verschwinden.
      function isSelfLeave() {
        return request.auth.uid in resource.data.memberUids
          && request.auth.uid != resource.data.ownerUid
          && !(request.auth.uid in request.resource.data.memberUids)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberUids', 'roles', 'memberNames'])
          && request.resource.data.memberUids.hasOnly(resource.data.memberUids)
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
          && request.resource.data.roles.diff(resource.data.roles).affectedKeys()
               .hasOnly([request.auth.uid])
          && request.resource.data.memberNames.diff(resource.data.memberNames).affectedKeys()
               .hasOnly([request.auth.uid]);
      }

      // Lesen darf jedes Mitglied.
      allow read: if isMember();

      // Erstellen: nur für sich selbst als alleiniges Erst-Mitglied.
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids.hasOnly([request.auth.uid])
        && request.auth.uid in request.resource.data.memberUids;

      // (a) Besitzer: darf alles ändern – inkl. Mitglieder entfernen –, aber der
      // Besitzer selbst darf nicht getauscht werden (Schutz vor Übernahme).
      allow update: if isOwner()
        && request.resource.data.ownerUid == resource.data.ownerUid;

      // (a2) Eigentumsübertragung: NUR der aktuelle Besitzer darf den Besitzer
      // wechseln – auf ein bestehendes Mitglied. Es ändern sich ausschließlich
      // ownerUid und roles (neuer Besitzer → 'owner', alter → 'editor').
      allow update: if isOwner()
        && request.resource.data.ownerUid != resource.data.ownerUid
        && request.resource.data.ownerUid in resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerUid', 'roles'])
        && request.resource.data.roles.diff(resource.data.roles).affectedKeys()
             .hasOnly([resource.data.ownerUid, request.resource.data.ownerUid])
        && request.resource.data.roles[request.resource.data.ownerUid] == 'owner'
        && request.resource.data.roles[resource.data.ownerUid] == 'editor';

      // (b) Mitglieder (Editoren): dürfen nur die App-Daten schreiben, NICHT die
      // Mitgliederliste – das verhindert, dass ein Editor andere Bewohner oder den
      // Besitzer aussperrt.
      allow update: if isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && membershipUnchanged();

      // (c) Selbst verlassen: ein Editor darf sich selbst (und nur sich) entfernen.
      allow update: if isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && isSelfLeave();

      // (d) Beitritt per Einladungslink: Ein Nicht-Mitglied darf sich selbst als
      // Editor hinzufügen – ausschließlich die Mitgliedschaftsfelder, und nur
      // wenn die im Schreibvorgang genannte Einladung existiert und aktiv ist.
      allow update: if isSignedIn()
        && !(request.auth.uid in resource.data.memberUids)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['memberUids', 'roles', 'memberNames', 'joinInviteId'])
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.roles.diff(resource.data.roles).affectedKeys()
             .hasOnly([request.auth.uid])
        && request.resource.data.roles[request.auth.uid] == 'editor'
        && get(/databases/$(database)/documents/profiles/$(profileId)/invites/$(request.resource.data.joinInviteId)).data.active == true;

      // Löschen darf nur der Besitzer.
      allow delete: if isOwner();

      // 3. Einladungen.
      match /invites/{inviteId} {
        function ownerUid() {
          return get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerUid;
        }

        // Einzelabruf: Wer die (geheime, zufällige) ID kennt und angemeldet
        // ist, darf die Einladung prüfen – nötig für den Beitritt.
        allow get: if request.auth != null;

        // Auflisten und Verwalten darf nur der Besitzer der Wohnung.
        allow list: if request.auth != null && request.auth.uid == ownerUid();
        allow create, update, delete: if request.auth != null && request.auth.uid == ownerUid();
      }
    }
  }
}

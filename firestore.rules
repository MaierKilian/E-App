rules_version = '2';

// Sicherheitsregeln für Firestore.
//
// Zwei Bereiche:
//  1. users/{uid}   – Alt-Daten (ein Profil pro Nutzer). Bleibt bestehen für die
//                     einmalige Migration und als Sicherung. Nur der Eigentümer.
//  2. profiles/{id} – Wohnprofile (mehrere pro Nutzer, später teilbar). Zugriff
//                     hat, wer in memberUids steht. In Stufe 1 ist das nur der
//                     Besitzer; der Einladungs-Beitritt kommt in Stufe 2 hinzu.
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Alt-Daten – unverändert.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Wohnprofile.
    match /profiles/{profileId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }

      // Lesen darf jedes Mitglied.
      allow read: if isMember();

      // Erstellen: nur für sich selbst als alleiniges Erst-Mitglied.
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids.hasOnly([request.auth.uid])
        && request.auth.uid in request.resource.data.memberUids;

      // Ändern darf jedes Mitglied – der Besitzer darf aber nicht heimlich
      // getauscht werden (Schutz vor Übernahme).
      allow update: if isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid;

      // Löschen darf nur der Besitzer.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;
    }
  }
}

# Firebase Web-Konfiguration
#
# So kommst du an die Werte:
#   Firebase Console → Projekteinstellungen (Zahnrad) → Tab "Allgemein"
#   → ganz unten "Deine Apps" → Web-App auswählen (oder anlegen)
#   → "SDK-Konfiguration" → "Konfiguration" (config-Objekt)
#
# Diese Werte sind KEINE Geheimnisse, sie dürfen öffentlich im Browser stehen.
#
# 1. Diese Datei nach ".env" kopieren:  cp .env.example .env
# 2. Werte unten aus der Console eintragen.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=e-app-info.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=e-app-info
VITE_FIREBASE_STORAGE_BUCKET=e-app-info.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
